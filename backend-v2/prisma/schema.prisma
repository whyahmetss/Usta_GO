// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model - Supports CUSTOMER, USTA (Service Provider), ADMIN
model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  bio       String?

  birthDate DateTime?  // 18+ doğrulama için
  role      UserRole   @default(CUSTOMER)  // CUSTOMER, USTA, ADMIN, SUPPORT

  // Account status
  status    UserStatus @default(ACTIVE)

  // Profile info
  profileImage String?
  ratings   Float      @default(0)
  balance   Float      @default(0)
  isActive  Boolean    @default(true)  // Usta: iş almayı aç/kapat

  // Push Notifications
  fcmToken  String?   // Firebase Cloud Messaging token

  // Referral
  referralCode   String?  @unique

  // Relations
  createdJobs Job[]       @relation("jobsAsCustomer")
  acceptedJobs Job[]      @relation("jobsAsUsta")
  offeredOn   Offer[]     @relation("offers")
  customerReviews  Review[]  @relation("CustomerReviews")
  ustaReviews      Review[]  @relation("UstaReviews")
  sentMessages     Message[] @relation("sender")
  receivedMessages Message[] @relation("receiver")
  transactions Transaction[]
  complaints   Complaint[]    @relation("complaintsFiled")
  couponUsages CouponUsage[]
  packages     UserPackage[]
  certificates     UserCertificate[]
  supportSessions  SupportSession[]  @relation("UserSessions")
  agentSessions    SupportSession[]  @relation("AgentSessions")
  notifications Notification[]
  bakiyeTalepleri BakiyeTalebi[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

enum UserRole {
  CUSTOMER
  USTA
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING_APPROVAL  // Usta: admin onayı bekliyor
  BANNED
  SUSPENDED
  DELETED
}

// Job Model
model Job {
  id          String      @id @default(cuid())

  // Job details
  title       String
  description String      @db.Text
  category    String
  location    String
  budget      Float

  // Job status
  status      JobStatus   @default(PENDING)

  // Customer photos (uploaded during job creation)
  photos       String[]    @default([])

  // Job photos (before/after by professional)
  beforePhotos String[]    @default([])
  afterPhotos  String[]    @default([])

  // Job timeline
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  ratedAt      DateTime?

  // Payment tracking
  paidAmount   Float       @default(0)

  // Cancellation details
  cancelReason String?
  cancelPenalty Float?

  // Rating details
  rating       Float?
  ratingReview String?     @db.Text

  // Relations
  customerId  String
  customer    User        @relation("jobsAsCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  ustaId      String?
  usta        User?       @relation("jobsAsUsta", fields: [ustaId], references: [id], onDelete: SetNull)

  offers      Offer[]
  reviews     Review[]
  transactions Transaction[]
  complaints  Complaint[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([customerId])
  @@index([ustaId])
  @@index([status])
  @@index([category])
  @@index([location])
}

enum JobStatus {
  PENDING            // Waiting for offers
  ACCEPTED           // Accepted by professional
  IN_PROGRESS        // Work in progress
  PENDING_APPROVAL   // Usta finished, waiting for customer approval
  COMPLETED          // Customer approved, payment done
  RATED              // Job completed and rated
  CANCELLED          // Job cancelled
}

// Offer Model
model Offer {
  id        String      @id @default(cuid())

  // Offer details
  price     Float
  message   String?     @db.Text

  // Offer status
  status    OfferStatus @default(PENDING)

  // Relations
  jobId     String
  job       Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  ustaId    String
  usta      User        @relation("offers", fields: [ustaId], references: [id], onDelete: Cascade)

  acceptedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([jobId, ustaId])
  @@index([jobId])
  @@index([ustaId])
  @@index([status])
}

enum OfferStatus {
  PENDING    // Waiting for customer response
  ACCEPTED   // Accepted by customer
  REJECTED   // Rejected by customer
  WITHDRAWN  // Withdrawn by USTA
}

// Review Model
model Review {
  id        String   @id @default(cuid())

  // Review details
  rating    Int      // 1-5 stars
  comment   String?  @db.Text

  // Relations
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  customerId String
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)

  ustaId    String
  usta      User     @relation("UstaReviews", fields: [ustaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId])
  @@index([jobId])
  @@index([customerId])
  @@index([ustaId])
}

// Message Model - For Socket.IO integration
model Message {
  id        String   @id @default(cuid())

  content   String   @db.Text

  // Relations
  senderId  String
  sender    User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User    @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  // Message metadata
  isRead    Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
}

// Transaction Model - For wallet transactions
model Transaction {
  id        String   @id @default(cuid())

  // Transaction details
  amount    Float
  type      TransactionType  // EARNING, WITHDRAWAL, REFUND
  status    TransactionStatus @default(COMPLETED)
  description String?  @db.Text

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([jobId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum TransactionType {
  EARNING
  WITHDRAWAL
  JOB_PAYMENT // Müşteri iş oluştururken cüzdandan düşen tutar (para çekme değil)
  REFUND
  COUPON
  REFERRAL
  TOPUP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// Complaint Model - For customer/usta complaints
model Complaint {
  id        String          @id @default(cuid())

  // Complaint details
  reason    String          // e.g. "Geç kaldı", "İşi yapmıyor", "Terbiyesiz", "Farklı bir sorun"
  details   String?         @db.Text
  status    ComplaintStatus @default(OPEN)

  // Relations
  jobId     String
  job       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  filedById String
  filedBy   User            @relation("complaintsFiled", fields: [filedById], references: [id], onDelete: Cascade)

  filedAt   DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([jobId])
  @@index([filedById])
  @@index([status])
}

enum ComplaintStatus {
  OPEN
  RESOLVED
  REJECTED
}

// Coupon Model - Admin creates, customers redeem
model Coupon {
  id          String        @id @default(cuid())
  code        String        @unique
  amount      Float
  description String?
  isActive    Boolean       @default(true)
  maxUses     Int?
  usedCount   Int           @default(0)
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  usages      CouponUsage[]

  @@index([code])
  @@index([isActive])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt    DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
  @@index([couponId])
}

// Sistem konfigürasyonu — iptal oranları vb.
model AppConfig {
  id    String   @id @default(cuid())
  key   String   @unique
  value String   @db.Text  // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([key])
}

// AI Fiyat Servisleri — Admin CRUD, AI sınıflandırma için kullanılır
model Service {
  id           String   @id @default(cuid())
  category     String   @unique  // ELECTRICAL_SOCKET, PLUMBING_LEAK, vb.
  label        String            // Türkçe etiket: "Priz Tamiri"
  basePrice    Float             // TL cinsinden temel fiyat (orta band)
  minPrice     Float?            // Alt fiyat bandı
  maxPrice     Float?            // Üst fiyat bandı
  homeCategory String?           // electric | plumbing | renovation | cleaning | painting | carpentry
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([homeCategory])
}

// Bakım Paketi Konfigürasyonu — Admin tarafından yönetilir
model PackageConfig {
  id        String   @id @default(cuid())
  packageId String   @unique  // klasik | pro | plus
  name      String
  price     Float
  badge     String   @default("📦")
  features  String   @db.Text  // JSON array
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
}

// Bakım Paketi — Müşteri satın alır, aylık otomatik yenilenir
model UserPackage {
  id          String        @id @default(cuid())
  packageId   String        // klasik | pro | plus
  packageName String
  price       Float

  autoRenew   Boolean       @default(true)
  status      PackageStatus @default(ACTIVE)

  startDate   DateTime      @default(now())
  nextRenewal DateTime

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

enum PackageStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

// Kalıcı Bildirimler
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // job | message | system
  title       String
  message     String   @db.Text
  icon        String?
  read        Boolean  @default(false)
  readAt      DateTime?
  jobId       String?
  targetUrl   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([read])
}

// Kampanya / Etkinlik — Admin yönetir, ana sayfada gösterilir
model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  badgeText   String?  @map("badge_text")
  buttonText  String?  @map("button_text")
  bgColor     String   @default("#111827") @map("bg_color")
  badgeColor  String   @default("#34d399") @map("badge_color")
  textColor   String   @default("#ffffff") @map("text_color")
  bgImage     String?  @map("bg_image")   // Arka plan resmi URL
  iconType    String?  @map("icon_type")  // flower, zap, gift, sparkles, heart, star, party
  iconImage   String?  @map("icon_image") // Ozel ikon resmi URL (oncelikli)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// E-posta OTP doğrulama
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("EMAIL_VERIFY") // EMAIL_VERIFY | PASSWORD_RESET
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
}

// Usta/Müşteri belge — Admin onayı için
model UserCertificate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl     String
  docType     String?  // kimlikOn, kimlikArka, ikametgah, meslek, adliSicil, vergi, profil vb.
  label       String?
  status      String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  adminNote   String?

  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  @@index([userId])
  @@index([status])
}

// Havale/EFT ile bakiye talebi
model BakiyeTalebi {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutar        Float
  referansKodu String              @unique
  durum        BakiyeTalebiDurum   @default(BEKLIYOR)
  adminNot     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId])
  @@index([durum])
  @@index([referansKodu])
}

enum BakiyeTalebiDurum {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

// Canlı Destek Oturumu
model SupportSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  agentId    String
  agent      User      @relation("AgentSessions", fields: [agentId], references: [id], onDelete: Cascade)
  status     String    @default("OPEN")   // OPEN | CLOSED
  rating     Int?
  ratingNote String?
  openedAt   DateTime  @default(now())
  closedAt   DateTime?

  @@index([userId])
  @@index([agentId])
  @@index([status])
}
